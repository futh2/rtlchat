{
  "manifest_version": 3,
  "name": "RTL Free — إصلاح الاتجاه العربي الاحترافي",
  "short_name": "RTL Free",
  "version": "1.1.6",
  "description": "إصلاح اتجاه النصوص العربية على المواقع التي تختار تفعيلها، مع خطوط منتقاة وتحكّم كامل. تصميم: RTLCHAT.",
  "author": "RTLCHAT",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "sidePanel"
  ],

  "commands": {
    "toggle-site": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "تفعيل/تعطيل RTL Free على الموقع الحالي"
    },
    "cycle-font": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Alt+Shift+F"
      },
      "description": "تبديل الخط العربي"
    },
    "increase-size": {
      "description": "تكبير الخط"
    },
    "decrease-size": {
      "description": "تصغير الخط"
    }
  },

  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "RTL Free — إصلاح الاتجاه العربي",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
